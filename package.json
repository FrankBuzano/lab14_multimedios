{
  "name": "lab14_multimedios",
  "version": "1.0.0",
  "description": "API REST DiscoStore - catalogo de albumes con Node.js, Express y SQLite",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --env-file=.env index.js",
    "start": "node --env-file=.env index.js",
    "db:create": "node data/createdb.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "express",
    "api-rest",
    "sqlite",
    "discostore",
    "albumes"
  ],
  "author": "Frank Buzano Sosa",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^10.0.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
